{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "./src",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist"
  },
  "include": ["src"],
  "exclude": [
    "src/main.tsx",
    "src/test",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
